# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# CORS 允许的来源（逗号分隔，生产环境建议指定具体域名）
# CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*

# ==================== 功能开关 ====================
# 是否启用上下文管理
CONTEXT_ENABLED=true

# ==================== 存储配置 ====================
# 存储类型: local, redis, mysql, pgsql
SERVER_STORAGE_TYPE=local
# 存储连接地址（local 模式留空）
# SERVER_STORAGE_URL=redis://localhost:6379/0
